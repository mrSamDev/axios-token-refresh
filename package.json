{
  "name": "@mrsamdev/axios-token-refresh",
  "version": "0.1.4",
  "description": "Axios plugin to handle token refresh and request queueing on authentication failures",
  "keywords": [
    "authentication",
    "axios",
    "interceptor",
    "jwt",
    "oauth",
    "refresh",
    "token"
  ],
  "homepage": "https://github.com/mrsamdev/axios-token-refresh#readme",
  "bugs": {
    "url": "https://github.com/mrsamdev/axios-token-refresh/issues"
  },
  "license": "MIT",
  "author": "MrSamDev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrsamdev/axios-token-refresh.git"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.cts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "eslint \"src/**/*.{ts,mts}\" \"*.{js,mjs,ts}\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "publish:jsr": "jsr publish",
    "publish:jsr:dry-run": "jsr publish --dry-run",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check ."
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "@vitest/coverage-v8": "^3.2.7",
    "axios": "^1.4.0",
    "axios-mock-adapter": "^1.21.5",
    "eslint": "^9.23.0",
    "opensrc": "^0.6.0",
    "oxfmt": "^0.59.0",
    "tsdown": "^0.22.7",
    "typescript": "^5.8.2",
    "vitest": "^3.2.7"
  },
  "peerDependencies": {
    "axios": ">=0.21.0"
  },
  "engines": {
    "node": ">=18"
  }
}
