{
  "name": "@mrsamdev/axios-token-refresh",
  "version": "0.0.4",
  "description": "Axios plugin to handle token refresh and request queueing on authentication failures",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "lint": "eslint src",
    "prepublishOnly": "npm run build",
    "docs": "jsdoc -c jsdoc.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "axios",
    "token",
    "refresh",
    "authentication",
    "interceptor",
    "oauth",
    "jwt"
  ],
  "author": "MrSamDev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrsamdev/axios-token-refresh.git"
  },
  "bugs": {
    "url": "https://github.com/mrsamdev/axios-token-refresh/issues"
  },
  "homepage": "https://github.com/mrsamdev/axios-token-refresh#readme",
  "peerDependencies": {
    "axios": ">=0.21.0"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "@vitest/coverage-v8": "^1.6.0",
    "axios": "^1.4.0",
    "axios-mock-adapter": "^1.21.5",
    "eslint": "^9.23.0",
    "jsdoc": "^4.0.2",
    "opensrc": "^0.6.0",
    "terser": "^5.37.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^1.6.0"
  }
}
